local function getFormattedTime()
    local t = os.date("*t")
    return string.format("%s %02d %04d - %02d:%02d:%02d",
        os.date("%B", os.time()),
        t.day,
        t.year,
        t.hour,
        t.min,
        t.sec
    )
end

local function parseText(text)
    text = text:gsub("%[time%]", getFormattedTime())
    text = text:gsub("%[name%]", LocalPlayer.Name)
    text = text:gsub("%[display%]", LocalPlayer.DisplayName)
    return text
end

