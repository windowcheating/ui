--// DETACH LEFT HAND
local function detachLeftHand(player)
    local character = player.Character
    if not character then return end
    
    local leftHand = character:FindFirstChild("LeftHand") or 
                     character:FindFirstChild("Left Arm") or
                     character:FindFirstChild("LeftArm")
    
    if not leftHand then return end
    if detachedParts[player] then return end
    
    local originalParent = leftHand.Parent
    local originalCFrame = leftHand.CFrame
    
    local torso = character:FindFirstChild("UpperTorso") or character:FindFirstChild("Torso")
    local relativeCFrame = nil
    if torso then
        relativeCFrame = torso.CFrame:ToObjectSpace(originalCFrame)
    end
    
    local weldsToRemove = {}
    for _, weld in ipairs(character:GetDescendants()) do
        if weld:IsA("Weld") or weld:IsA("Motor6D") then
            if weld.Part0 == leftHand or weld.Part1 == leftHand then
                table.insert(weldsToRemove, weld)
            end
        end
    end
    
    for _, weld in ipairs(weldsToRemove) do
        weld:Destroy()
    end
    
    leftHand.LocalTransparencyModifier = 1
    leftHand.Transparency = 1
    
    leftHand.Parent = workspace
    leftHand.CFrame = originalCFrame
    
    detachedParts[player] = {
        Part = leftHand,
        OriginalParent = originalParent,
        OriginalCFrame = originalCFrame,
        RelativeCFrame = relativeCFrame,
        Torso = torso
    }
end

--// REATTACH LEFT HAND
local function reattachLeftHand(player)
    if not detachedParts[player] then return end
    
    local data = detachedParts[player]
    local part = data.Part
    local originalParent = data.OriginalParent
    local originalCFrame = data.OriginalCFrame
    local relativeCFrame = data.RelativeCFrame
    local torso = data.Torso or originalParent:FindFirstChild("UpperTorso") or originalParent:FindFirstChild("Torso")
    
    if part and originalParent then
        if torso and relativeCFrame then
            part.CFrame = torso.CFrame * relativeCFrame
        elseif originalCFrame then
            part.CFrame = originalCFrame
        end
        
        part.LocalTransparencyModifier = 0
        part.Transparency = 0
        
        part.Parent = originalParent
        
        local leftShoulder = originalParent:FindFirstChild("LeftShoulder") or 
                             originalParent:FindFirstChild("Left Arm") or
                             originalParent:FindFirstChild("LeftArm")
        
        if leftShoulder and leftShoulder:IsA("Motor6D") then
            leftShoulder.Part0 = torso or originalParent:FindFirstChild("UpperTorso") or originalParent:FindFirstChild("Torso")
            leftShoulder.Part1 = part
        else
            local newWeld = Instance.new("Weld")
            local torsoPart = torso or originalParent:FindFirstChild("UpperTorso") or originalParent:FindFirstChild("Torso")
            newWeld.Part0 = torsoPart
            newWeld.Part1 = part
            if torsoPart then
                newWeld.C0 = torsoPart.CFrame:Inverse() * part.CFrame
                newWeld.Parent = part
            end
        end
    end
    
    detachedParts[player] = nil
end

