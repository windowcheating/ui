--// GET CLOSEST PLAYER
local function getClosestPlayer()
    local closest, dist = nil, math.huge
    local mouse = LocalPlayer:GetMouse()
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local pos, onScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if onScreen then
                local mag = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if mag < dist then
                    dist = mag
                    closest = v
                end
            end
        end
    end
    return closest
end

--// GET PLAYER BY USER ID
local function getPlayerByUserId(userId)
    for _, player in ipairs(Players:GetPlayers()) do
        if player.UserId == userId then
            return player
        end
    end
    return nil
end

--// GET TARGET PART - WITH FALLBACKS
local function getTargetPart()
    if not lockedTarget then return nil end
    
    local target = lockedTarget
    if not target or not target.Parent then
        if lockedTargetUserId then
            target = getPlayerByUserId(lockedTargetUserId)
            if target then
                lockedTarget = target
                targetPlayer = target
            else
                return nil
            end
        else
            return nil
        end
    end
    
    if not target.Character or not target.Character.Parent then
        return nil
    end
    
    local handData = detachedParts[target]
    if handData and handData.Part and handData.Part.Parent then
        return handData.Part
    end
    
    local head = target.Character:FindFirstChild("Head")
    if head and head.Parent then
        return head
    end
    
    local torso = target.Character:FindFirstChild("UpperTorso")
    if torso and torso.Parent then
        return torso
    end
    
    local hrp = target.Character:FindFirstChild("HumanoidRootPart")
    if hrp and hrp.Parent then
        return hrp
    end
    
    return nil
end

--// INVISIBLE TRACERS
local function handleTracer(obj)
    if not bulletTPEnabled then return end
    local n = obj.Name:lower()
    if n:find("tracer") or n:find("bullet") or n:find("beam") or obj:IsA("Trail") or obj:IsA("Beam") then
        task.spawn(function()
            while bulletTPEnabled and obj and obj.Parent do
                if obj:IsA("BasePart") then 
                    obj.Transparency = 1
                    obj.LocalTransparencyModifier = 1
                elseif obj:IsA("Trail") or obj:IsA("Beam") then 
                    obj.Enabled = false 
                end
                task.wait()
            end
        end)
    end
end

