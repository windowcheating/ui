--// HUD UPDATE
local function updateHUD()
    if not lockedTarget or not lockedTarget.Character then
        container.Visible = false
        return
    end
    
    local char = lockedTarget.Character
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local foot = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightFoot") or hrp
    
    if not hum or not hrp or not foot then
        container.Visible = false
        return
    end
    
    nameLbl.Text = "Player: " .. lockedTarget.Name
    toolLbl.Text = "Tool: " .. (char:FindFirstChildOfClass("Tool") and char:FindFirstChildOfClass("Tool").Name or "None")
    
    local bodyEffects = char:FindFirstChild("BodyEffects")
    local isKO = (bodyEffects and (bodyEffects:FindFirstChild("K.O") or bodyEffects:FindFirstChild("KO")))
    if (isKO and isKO.Value == true) or hum.Health <= 0.1 then
        lockLbl.Text = "Status: <font color=\"" .. themes.down_hex .. "\">Down</font>"
    else
        lockLbl.Text = "Status: <font color=\"" .. themes.alive_hex .. "\">Alive</font>"
    end
    
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        distLbl.Text = "Distance: " .. math.floor((hrp.Position - myChar.HumanoidRootPart.Position).Magnitude) .. " studs"
    else
        distLbl.Text = "Distance: N/A"
    end
    posLbl.Text = string.format("Pos: X:%.1f Y:%.1f Z:%.1f", hrp.Position.X, hrp.Position.Y, hrp.Position.Z)
    
    hpFill.Size = UDim2.new(math.clamp(hum.Health / hum.MaxHealth, 0, 1), -2, 1, -2)
    hpValText.Text = math.floor(hum.Health) .. "/" .. math.floor(hum.MaxHealth)
    
    local armorObj = (bodyEffects and bodyEffects:FindFirstChild("Armor")) or char:FindFirstChild("Armor")
    local armorAmt = (armorObj and armorObj.Value) or 0
    local maxArmor = (armorObj and (armorObj:FindFirstChild("MaxArmor") or armorObj:FindFirstChild("Max"))) and (armorObj:FindFirstChild("MaxArmor") or armorObj:FindFirstChild("Max")).Value or 100
    armorFill.Size = UDim2.new(math.clamp(armorAmt / maxArmor, 0, 1), -2, 1, -2)
    armorValText.Text = math.floor(armorAmt) .. "/" .. math.floor(maxArmor)
    
    pfp.Image = "rbxthumb://type=AvatarHeadShot&id=" .. lockedTarget.UserId .. "&w=150&h=150"
    
    container.Visible = true
end

